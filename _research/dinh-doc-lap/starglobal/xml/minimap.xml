<krpano>


	<action name="mapspot_loadscene">
		if(layer[map].scale GT 0.25,
			set(layer[map].enabled, false);
			tween(layer[map].alpha, 0.0, 0.25, default,
				loadscene(%1, null, MERGE, BLEND(1));
				set(layer[map].onclick, openmap(););
				layer[map].changeorigin(leftbottom,leftbottom);
				set(layer[map].x, 0);
				set(layer[map].y, 50);
				set(layer[map].scale, 0.1);
				set(events[sceneload].onloadcomplete,
					delayedcall(1,
						tween(layer[map].alpha, 1.0, 0.5, default, set(layer[map].enabled, true); );
					  );
				  );
			  );
		  ,
			<!-- small map: just load the scene -->
			loadscene(%1, null, MERGE, BLEND(1));-
		  );
	</action>
	
		<!-- map opening - scale the map up to 100% (or smaller if the screen is too small) -->
	<action name="openmap">
		layer[map].changeorigin(center,center);
		set(bigscale,1.6);
		set(big,1);
		if(layer[map].imagewidth GT stagewidth, div(bigscale, stagewidth, layer[map].imagewidth); );
		mul(bigscale,0.8);
		tween(layer[map].x, 0);
		tween(layer[map].y, 0);
		tween(layer[map].scale, get(bigscale));
		set(layer[map].visible,true);
		set(layer[open_map].visible,false);
		set(events[test].onmousedown, closemap());
		js('(closeThumbnail())');
	</action>
	
	


	<!-- map closing - scale the map back to 0.25 of its image pixelsize -->
	<action name="closemap" autorun="preinit">
		set(bigscale,0.08);
		set(big,0);
		layer[map].changeorigin(rightbottom,rightbottom);
		tween(layer[map].x, 10);
		tween(layer[map].y, 50);
		tween(layer[map].scale, get(bigscale));
		set(layer[map].visible,false);
		set(layer[open_map].visible,true);
		set(events[test].onmousedown, null);
		js('(openThumbnail())');
	</action>
	
<!-- the map image -->
	<layer name="map" url="map/map-background.png" keep="true"
	       align="rightbottom"
	       scale="1" scalechildren="true"
		   visible="false"
	       onclick="js('')"
	       />
	       
	<layer name="open_map" url="map/map-background.png" keep="true" handcursor="false" capture="false"
	       align="rightbottom"
		   visible="true"
	       scale="0.1" scalechildren="true"
	       onclick="openmap();"
		   x= "10"
		   y= "50"
	       />
	         
		   
