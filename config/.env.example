# Sao chép file này thành .env và điền thông tin thật
# Dùng 127.0.0.1 thay cho "localhost" để tránh PDO tự chuyển sang socket sai đường dẫn.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=vr360_cms
DB_USER=root
DB_PASS=

# (Tuỳ chọn) Kết nối qua unix socket thay vì TCP — để trống nếu dùng host:port ở trên.
# aaPanel/BT thường là /tmp/mysql.sock; một số bản là /www/server/data/mysql.sock
DB_SOCKET=

# URL gốc của hệ thống (không có dấu / cuối)
BASE_URL=http://localhost:8000

# Khoá bảo mật session
APP_SECRET=change-this-to-a-random-string

# Bật để xem chi tiết lỗi DB khi gặp sự cố (TẮT ở production)
APP_DEBUG=false
